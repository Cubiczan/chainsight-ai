DATABASE_URL=file:./db/custom.db

# Static API key for POST /api/analyze. Sent as `Authorization: Bearer <key>`.
# When SET, /api/analyze requires the bearer token and calls the live LLM.
# When UNSET (offline/mock mode), /api/analyze serves deterministic SYNTHETIC
# analysis instead of failing — so the demo works with zero credentials.
ANALYZE_API_KEY=

# ── Offline / mock mode ──────────────────────────────────────────────────────
# Live Mantle chain data source (RPC/indexer). Leave unset (or as the placeholder)
# to run fully offline against embedded synthetic on-chain data.
MANTLE_RPC_URL=

# Force offline/mock mode regardless of any credentials present. Accepts
# 1 / true / mock / yes. With no MANTLE_RPC_URL the app is offline automatically.
CHAINSIGHT_OFFLINE=
